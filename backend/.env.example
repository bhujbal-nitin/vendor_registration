# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=purchase_edge

# SMTP (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Vendor Portal

# AutomationEdge T4 — workflow integration
AE_T4_BASE_URL=https://t4.automationedge.com
AE_T4_USERNAME=your_ae_username
AE_T4_PASSWORD=your_ae_password
AE_T4_WORKFLOW_NAME=your_workflow_name
AE_T4_EXECUTE_PATH=/aeengine/rest/execute
AE_T4_AUTH_HEADER=Authorization
AE_T4_AGENT_NAME=username@hostname
AE_T4_DECRYPT_KEY=your_aes_decryption_key
AE_T4_USER_ID=your_ae_user_id
AE_T4_SOURCE=VendorPortal

# Tally — vendor ledger sync on approval
TALLY_URL=http://localhost:9000
TALLY_COMPANY_NAME=Your Tally Company Name
TALLY_LEDGER_PARENT=Sundry Creditors
TALLY_ISBILLWISEON=Yes
TALLY_GST_REGISTRATION_TYPE=Regular
TALLY_COUNTRY=India
TALLY_TRANSACTION_NAME=Primary
TALLY_DEFAULT_TRANSACTION_TYPE=e-Fund Transfer
TALLY_FY_START_MONTH=4
TALLY_FY_START_DAY=1

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=True
